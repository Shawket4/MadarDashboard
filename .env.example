# Copy to .env for local dev. The dashboard talks to the dedicated API origin
# (api.madar-pos.cloud); the main madar-pos.cloud vhost no longer proxies /api.
# For local backend dev, point VITE_API_URL at http://localhost:8082 instead.
VITE_API_URL=https://api.madar-pos.cloud

# Origin of the management dashboard — used by the standalone landing
# (get.madar-pos.cloud) for its cross-origin "Sign in" / "Get started" links.
VITE_DASHBOARD_URL=https://madar-pos.cloud
