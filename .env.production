# Production build (vite build / tauri build) — real backend.
# Local dev uses .env (localhost). This file overrides it in production mode only.
# The dashboard talks to the dedicated API origin (cross-origin; CORS allows it);
# the main madar-pos.cloud vhost no longer proxies /api.
VITE_API_URL=https://api.madar-pos.cloud
VITE_DASHBOARD_URL=https://madar-pos.cloud
